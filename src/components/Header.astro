---
import { SITE_TITLE } from '../consts';
import { getNavLinks } from '../data/navLinks';

const BASE = import.meta.env.BASE_URL;
const NAV_LINKS = getNavLinks(BASE);
---

<header class="site-header sticky top-0 z-50 border-b border-zinc-200/70 bg-zinc-50/72 backdrop-blur-xl transition-colors duration-200 dark:border-zinc-800/80 dark:bg-zinc-950/72">
	<nav class="page-shell flex h-16 items-center justify-between gap-4">
		<div class="flex items-center gap-6">
			<a href={BASE} class="group inline-flex items-center gap-2 rounded-full border border-zinc-200/75 bg-white/70 px-3 py-1.5 text-zinc-800 shadow-[0_8px_20px_rgba(15,23,42,0.04)] backdrop-blur-md transition-all duration-200 hover:border-zinc-300/95 hover:bg-white/92 hover:text-zinc-950 dark:border-zinc-700/75 dark:bg-zinc-900/68 dark:text-zinc-100 dark:shadow-[0_8px_18px_rgba(0,0,0,0.16)] dark:hover:border-zinc-500/95 dark:hover:bg-zinc-800/92">
				<span class="text-[1.06rem] font-semibold leading-none">{SITE_TITLE}</span>
			</a>
			<div class="hidden items-center gap-1 text-sm md:flex">
				{
					NAV_LINKS.map((link) => (
						<a
							href={link.href}
							class="nav-item rounded-xl border border-transparent px-3 py-1.5 text-sm font-medium text-zinc-600 dark:text-zinc-300 dark:border-transparent"
						>
							<span class="nav-item-label">{link.label}</span>
						</a>
					))
				}
			</div>
		</div>
		<div class="flex items-center gap-2">
			<button
				type="button"
				id="theme-toggle"
				class="theme-toggle relative inline-flex h-9 w-9 items-center justify-center rounded-xl border border-zinc-200/75 bg-white/70 text-zinc-600 shadow-[0_6px_16px_rgba(15,23,42,0.04)] backdrop-blur-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-zinc-300 hover:bg-white hover:text-zinc-900 hover:shadow-[0_10px_22px_rgba(15,23,42,0.1)] active:scale-95 dark:border-zinc-700/80 dark:bg-zinc-900/68 dark:text-zinc-300 dark:shadow-[0_8px_18px_rgba(0,0,0,0.16)] dark:hover:-translate-y-0.5 dark:hover:border-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-zinc-100"
				aria-label="Toggle theme"
			>
				<svg class="theme-icon sun-icon absolute h-[18px] w-[18px] fill-current transition-all duration-300 dark:opacity-0 dark:rotate-90 dark:scale-0" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M12 4a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V5a1 1 0 0 1 1-1Zm0 13a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1Zm8-5a1 1 0 0 1-1 1h-1a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1ZM7 12a1 1 0 0 1-1 1H5a1 1 0 1 1 0-2h1a1 1 0 0 1 1 1Zm9.7-5.3a1 1 0 0 1 0 1.4L16 8.8a1 1 0 1 1-1.4-1.4l.7-.7a1 1 0 0 1 1.4 0Zm-7.3 7.3a1 1 0 0 1 0 1.4l-.7.7a1 1 0 0 1-1.4-1.4l.7-.7a1 1 0 0 1 1.4 0Zm7.3 2.1a1 1 0 0 1-1.4 1.4l-.7-.7a1 1 0 0 1 1.4-1.4l.7.7ZM9.4 8.8A1 1 0 0 1 8 8.8l-.7-.7a1 1 0 1 1 1.4-1.4l.7.7a1 1 0 0 1 0 1.4ZM12 8a4 4 0 1 1 0 8 4 4 0 0 1 0-8Z" />
				</svg>
				<svg class="theme-icon moon-icon absolute h-[18px] w-[18px] fill-current transition-all duration-300 opacity-0 -rotate-90 scale-0 dark:opacity-100 dark:rotate-0 dark:scale-100" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M21.64 13a1 1 0 0 0-1.05-.14 8.05 8.05 0 0 1-3.37.73 8.15 8.15 0 0 1-8.14-8.1 8.59 8.59 0 0 1 .25-2A1 1 0 0 0 8 2.36 10.14 10.14 0 1 0 22 14.05a1 1 0 0 0-.36-1.05Z" />
				</svg>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	(() => {
		const STORAGE_KEY = "theme";

		const getInitialTheme = () => {
			const stored = localStorage.getItem(STORAGE_KEY);
			if (stored === "dark" || stored === "light") return stored;
			return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
		};

		const applyTheme = (theme) => {
			const root = document.documentElement;
			root.classList.toggle("dark", theme === "dark");
			root.dataset.theme = theme;
			const meta = document.querySelector('meta[name="theme-color"]');
			if (meta) meta.setAttribute("content", theme === "dark" ? "#09090b" : "#fafafa");
		};

		// Apply initial theme immediately to prevent FOUC
		applyTheme(getInitialTheme());

		const initToggle = () => {
			const buttons = document.querySelectorAll("#theme-toggle");
			if (!buttons.length) return;
			buttons.forEach((button) => {
				if (button.dataset.bound === "true") return;
				button.dataset.bound = "true";
				button.addEventListener("click", () => {
					const isDark = document.documentElement.classList.contains("dark");
					const next = isDark ? "light" : "dark";
					applyTheme(next);
					localStorage.setItem(STORAGE_KEY, next);
				});
			});
		};

		initToggle();
		document.addEventListener("astro:page-load", initToggle);
	})();
</script>
