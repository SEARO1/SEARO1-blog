---
interface Props {
	tags: string[];
	base?: string;
	maxMobile?: number;
	maxDesktop?: number | null;
}

const { tags, base = import.meta.env.BASE_URL || '/SEARO1-blog', maxMobile = 3, maxDesktop = 3 } = Astro.props;

const cleanBase = base.replace(/\/$/, '');

function getTagSlug(tag: string): string {
	return tag.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
}

const visibleMobile = tags.slice(0, maxMobile);
const visibleDesktop = tags.slice(0, maxDesktop ?? maxMobile);
const hiddenCount = tags.length - (maxDesktop ?? maxMobile);
---

<div class="flex flex-wrap gap-1.5">
	{visibleMobile.map((tag) => (
		<a
			href={`${cleanBase}/tags/${getTagSlug(tag)}/`}
			class="rounded-full border border-zinc-200 bg-zinc-50 px-2.5 py-0.5 text-xs font-medium text-zinc-600 transition-colors hover:border-zinc-300 hover:bg-zinc-100 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-400 dark:hover:border-zinc-600 dark:hover:bg-zinc-700"
		>
			{tag}
		</a>
	))}
	{visibleDesktop.length < tags.length && (
		<span class="rounded-full border border-zinc-200 bg-zinc-50 px-2.5 py-0.5 text-xs font-medium text-zinc-500 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-500">
			+{tags.length - (maxDesktop ?? maxMobile)}
		</span>
	)}
</div>