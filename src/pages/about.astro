---
import Layout from "../layouts/Layout.astro";
import { SITE_TITLE } from "../consts";

const BASE = import.meta.env.BASE_URL;
---

<Layout title={`About | ${SITE_TITLE}`}>
	<main class="page-shell py-10 md:py-14">
		<div class="mx-auto max-w-3xl">
			<!-- Hero Section -->
			<header class="mb-10">
				<p class="mb-1 text-xs font-medium uppercase tracking-[0.14em] text-zinc-400">About</p>
				<div class="flex items-center gap-5">
					<img
						src={`${BASE}/avatar.jpg`}
						alt="Cheung Wai Man"
						class="h-24 w-24 rounded-full object-cover ring-2 ring-zinc-200/50 dark:ring-zinc-700/50"
					/>
					<div>
						<h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 md:text-5xl">
							Cheung Wai Man
						</h1>
						<p class="mt-1 text-lg text-zinc-600 dark:text-zinc-400">
							Computer and Data Engineering Student · City University of Hong Kong
						</p>
					</div>
				</div>
				<div class="mt-4 flex flex-wrap gap-3">
					<a
						href="mailto:wmcheung85-c@my.cityu.edu.hk"
						class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 bg-white px-3 py-1.5 text-sm font-medium text-zinc-700 shadow-sm transition-colors hover:border-zinc-300 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700"
					>
						<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
						</svg>
						wmcheung85-c@my.cityu.edu.hk
					</a>
					<a
						href="https://github.com/SEARO1"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 bg-white px-3 py-1.5 text-sm font-medium text-zinc-700 shadow-sm transition-colors hover:border-zinc-300 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700"
					>
						<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
							<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
						</svg>
						SEARO1
					</a>
				</div>
			</header>

			<!-- Profile Summary -->
			<section class="mb-10">
				<h2 class="mb-3 text-xl font-semibold text-zinc-900 dark:text-zinc-100">Profile</h2>
				<p class="text-zinc-600 dark:text-zinc-400">
					Motivated Computer and Data Engineering student seeking an internship to apply expertise in programming, algorithm design, and networking. Passionate about bridging theoretical knowledge with real-world applications to develop scalable and secure solutions.
				</p>
			</section>

			<!-- Education -->
			<section class="mb-10">
				<h2 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-zinc-100">Education</h2>
				<div class="space-y-4">
					<div class="rounded-xl border border-zinc-200 bg-zinc-50/50 p-5 dark:border-zinc-800 dark:bg-zinc-900/50">
						<div class="flex items-start justify-between gap-3">
							<div>
								<h3 class="font-semibold text-zinc-900 dark:text-zinc-100">City University of Hong Kong</h3>
								<p class="text-sm text-zinc-600 dark:text-zinc-400">Bachelor of Engineering in Computer and Data Engineering</p>
							</div>
							<span class="shrink-0 rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700 dark:bg-green-900/40 dark:text-green-400">2024–Present</span>
						</div>
						<div class="mt-3 flex flex-wrap gap-1.5">
							<span class="rounded-md bg-zinc-200/70 px-2 py-0.5 text-xs font-medium text-zinc-700 dark:bg-zinc-700/60 dark:text-zinc-300">Microcomputer Systems</span>
							<span class="rounded-md bg-zinc-200/70 px-2 py-0.5 text-xs font-medium text-zinc-700 dark:bg-zinc-700/60 dark:text-zinc-300">Circuit Design</span>
							<span class="rounded-md bg-zinc-200/70 px-2 py-0.5 text-xs font-medium text-zinc-700 dark:bg-zinc-700/60 dark:text-zinc-300">Networking</span>
							<span class="rounded-md bg-zinc-200/70 px-2 py-0.5 text-xs font-medium text-zinc-700 dark:bg-zinc-700/60 dark:text-zinc-300">Java Programming</span>
						</div>
					</div>
					<div class="rounded-xl border border-zinc-200 bg-zinc-50/50 p-5 dark:border-zinc-800 dark:bg-zinc-900/50">
						<div class="flex items-start justify-between gap-3">
							<div>
								<h3 class="font-semibold text-zinc-900 dark:text-zinc-100">Hong Kong Community College</h3>
								<p class="text-sm text-zinc-600 dark:text-zinc-400">Associate Degree in Internet Technology</p>
							</div>
							<span class="shrink-0 rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs font-medium text-zinc-600 dark:bg-zinc-700/60 dark:text-zinc-400">2022–2024</span>
						</div>
						<p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">Notable coursework: Data Structure, Algorithm, Programming Language</p>
						<p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">Projects: Library management system, ATM system, web pages (HTML, C++, Java OOP)</p>
					</div>
				</div>
			</section>

			<!-- Technical Skills -->
			<section class="mb-10">
				<h2 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-zinc-100">Technical Skills</h2>
				<div class="grid gap-4 sm:grid-cols-2">
					<div class="rounded-xl border border-zinc-200 bg-zinc-50/50 p-5 dark:border-zinc-800 dark:bg-zinc-900/50">
						<h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Programming Languages</h3>
						<div class="flex flex-wrap gap-2">
							<span class="rounded-lg bg-blue-100 px-2.5 py-1 text-sm font-medium text-blue-700 dark:bg-blue-900/40 dark:text-blue-300">HTML</span>
							<span class="rounded-lg bg-purple-100 px-2.5 py-1 text-sm font-medium text-purple-700 dark:bg-purple-900/40 dark:text-purple-300">C++</span>
							<span class="rounded-lg bg-orange-100 px-2.5 py-1 text-sm font-medium text-orange-700 dark:bg-orange-900/40 dark:text-orange-300">Java</span>
							<span class="rounded-lg bg-yellow-100 px-2.5 py-1 text-sm font-medium text-yellow-700 dark:bg-yellow-900/40 dark:text-yellow-300">Python</span>
							<span class="rounded-lg bg-green-100 px-2.5 py-1 text-sm font-medium text-green-700 dark:bg-green-900/40 dark:text-green-300">SQL</span>
						</div>
					</div>
					<div class="rounded-xl border border-zinc-200 bg-zinc-50/50 p-5 dark:border-zinc-800 dark:bg-zinc-900/50">
						<h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">Core Concepts</h3>
						<div class="flex flex-wrap gap-2">
							<span class="rounded-lg bg-zinc-100 px-2.5 py-1 text-sm font-medium text-zinc-700 dark:bg-zinc-700/60 dark:text-zinc-300">Data Structure</span>
							<span class="rounded-lg bg-zinc-100 px-2.5 py-1 text-sm font-medium text-zinc-700 dark:bg-zinc-700/60 dark:text-zinc-300">Algorithm</span>
							<span class="rounded-lg bg-zinc-100 px-2.5 py-1 text-sm font-medium text-zinc-700 dark:bg-zinc-700/60 dark:text-zinc-300">OOP</span>
							<span class="rounded-lg bg-zinc-100 px-2.5 py-1 text-sm font-medium text-zinc-700 dark:bg-zinc-700/60 dark:text-zinc-300">Networking</span>
						</div>
					</div>
				</div>
			</section>

			<!-- Projects -->
			<section class="mb-10">
				<h2 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-zinc-100">Key Projects</h2>
				<div class="space-y-4">
					<div class="rounded-xl border border-zinc-200 bg-zinc-50/50 p-5 dark:border-zinc-800 dark:bg-zinc-900/50">
						<div class="flex items-start justify-between gap-3">
							<h3 class="font-semibold text-zinc-900 dark:text-zinc-100">AI Study Assistant Web App</h3>
							<span class="shrink-0 rounded-md bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700 dark:bg-amber-900/40 dark:text-amber-400">HTML/CSS/JS · AI APIs</span>
						</div>
						<p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
							Developed an interactive platform using HTML/CSS/JS and AI APIs to generate exercises, summaries, and explain concepts.
						</p>
					</div>
					<div class="rounded-xl border border-zinc-200 bg-zinc-50/50 p-5 dark:border-zinc-800 dark:bg-zinc-900/50">
						<div class="flex items-start justify-between gap-3">
							<h3 class="font-semibold text-zinc-900 dark:text-zinc-100">Mental Health Chatbot</h3>
							<span class="shrink-0 rounded-md bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700 dark:bg-amber-900/40 dark:text-amber-400">HTML/CSS/JS · face.js</span>
						</div>
						<p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
							Integrated face.js API for emotion tracking with an AI chatbot to support users' mental health.
						</p>
					</div>
					<div class="grid gap-4 sm:grid-cols-2">
						<div class="rounded-xl border border-zinc-200 bg-zinc-50/50 p-4 dark:border-zinc-800 dark:bg-zinc-900/50">
							<h3 class="font-semibold text-zinc-900 dark:text-zinc-100">Library Management System</h3>
							<span class="mt-1 block text-xs text-zinc-500 dark:text-zinc-400">C++</span>
							<p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">Efficient book tracking system</p>
						</div>
						<div class="rounded-xl border border-zinc-200 bg-zinc-50/50 p-4 dark:border-zinc-800 dark:bg-zinc-900/50">
							<h3 class="font-semibold text-zinc-900 dark:text-zinc-100">Banking Operations</h3>
							<span class="mt-1 block text-xs text-zinc-500 dark:text-zinc-400">Java</span>
							<p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">Secure banking operations system</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Awards -->
			<section class="mb-10">
				<h2 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-zinc-100">Awards</h2>
				<div class="rounded-xl border border-zinc-200 bg-gradient-to-r from-amber-50 to-yellow-50 p-5 dark:border-zinc-800 dark:from-amber-900/20 dark:to-yellow-900/20">
					<div class="flex items-center gap-3">
						<div class="flex h-10 w-10 items-center justify-center rounded-full bg-amber-100 dark:bg-amber-900/50">
							<svg class="h-5 w-5 text-amber-600 dark:text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
							</svg>
						</div>
						<div>
							<h3 class="font-semibold text-zinc-900 dark:text-zinc-100">2025 Tencent Hackathon AI Coding</h3>
							<p class="text-sm text-zinc-600 dark:text-zinc-400">First Prize (CityU) · Third Prize (Final)</p>
						</div>
					</div>
				</div>
			</section>
		</div>
	</main>
</Layout>
