---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import TerminalWidget from '../components/TerminalWidget.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

const BASE = import.meta.env.BASE_URL || '/SEARO1-blog';
const allPosts = await getCollection('blog');
const posts = allPosts
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = posts.slice(0, 6);
---

<Layout title={SITE_TITLE}>
  <!-- Hero Section with Terminal Widget -->
  <section class="py-10 md:py-14">
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
      <!-- Left: Blog Identity -->
      <div class="flex flex-col justify-center">
        <p class="mb-2 text-xs font-medium uppercase tracking-[0.14em] text-zinc-400">
          {new Date().getFullYear()}
        </p>
        <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 md:text-5xl lg:text-6xl">
          {SITE_TITLE}
        </h1>
        <p class="mt-3 text-lg text-zinc-600 dark:text-zinc-400">
          Research · Engineering · Notes
        </p>
        <p class="mt-4 text-base leading-relaxed text-zinc-500 dark:text-zinc-500">
          A personal space for technical writing, engineering notes, and everything in between.
        </p>
        
        <!-- Social Links -->
        <div class="mt-6 flex gap-4">
          <a 
            href="https://github.com/SEARO1" 
            target="_blank" 
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            GitHub
          </a>
          <a 
            href={`${BASE}/rss.xml`}
            class="flex items-center gap-2 text-sm text-zinc-500 transition-colors hover:text-orange-500 dark:text-zinc-400 dark:hover:text-orange-400"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
            RSS
          </a>
        </div>
      </div>
      
      <!-- Right: Terminal Widget -->
      <div class="flex items-center justify-center">
        <TerminalWidget 
          quote="The best way to predict the future is to invent it."
          author="Alan Kay"
        />
      </div>
    </div>
  </section>

  <!-- Decorative Divider -->
  <div class="flex items-center justify-center gap-1 py-6">
    <span class="h-1 w-1 rounded-full bg-zinc-300 dark:bg-zinc-700"></span>
    <span class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-600"></span>
    <span class="h-2 w-2 rounded-full bg-zinc-500 dark:bg-zinc-500"></span>
    <span class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-600"></span>
    <span class="h-1 w-1 rounded-full bg-zinc-300 dark:bg-zinc-700"></span>
  </div>

  <!-- Recent Posts Section -->
  <section class="mt-6">
    <div class="mb-6 flex items-center justify-between">
      <h2 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100">Recent Posts</h2>
      <a 
        href={`${BASE}/blog/`}
        class="text-sm font-medium text-blue-600 transition-colors hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
      >
        View all &rarr;
      </a>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {recentPosts.map((post) => (
        <PostCard post={post} base={BASE} />
      ))}
    </div>
  </section>
</Layout>