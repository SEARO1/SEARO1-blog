---
import Layout from "../layouts/Layout.astro";
---

<Layout title="SEARO1 Blog">
  <section class="py-12 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">Welcome to SEARO1 Blog</h1>
    <p class="mt-4 text-lg text-zinc-600 dark:text-zinc-400">
      Research · Engineering · Notes
    </p>
  </section>

  <section class="mt-12">
    <h2 class="mb-6 text-2xl font-semibold text-zinc-900 dark:text-zinc-100">Recent Posts</h2>
    <div class="grid gap-6">
      <article class="rounded-xl border border-zinc-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md dark:border-zinc-800 dark:bg-zinc-900">
        <p class="text-sm text-zinc-500 dark:text-zinc-400">Coming soon...</p>
        <h3 class="mt-2 text-xl font-semibold text-zinc-900 dark:text-zinc-100">First Post</h3>
        <p class="mt-2 text-zinc-600 dark:text-zinc-400">Stay tuned for updates!</p>
      </article>
    </div>
  </section>
</Layout>
