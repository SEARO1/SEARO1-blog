---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'SEARO1 Blog - Research · Engineering · Notes' } = Astro.props;
const BASE = import.meta.env.BASE_URL || '/SEARO1-blog';
---

<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="180x180" href={`${BASE}/favicon.png`} />
    <link rel="apple-touch-icon" href={`${BASE}/favicon.png`} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Serif+SC:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="alternate" type="application/rss+xml" title="SEARO1 Blog" href={`${BASE}/rss.xml`}>
  </head>
  <body class="min-h-screen bg-zinc-50 dark:bg-zinc-950">
    <!-- Decorative top gradient bar -->
    <div class="fixed inset-x-0 top-0 z-50 h-1 bg-gradient-to-r from-zinc-200 via-zinc-400 to-zinc-200 dark:from-zinc-700 dark:via-zinc-500 dark:to-zinc-700"></div>
    
    <!-- Header -->
    <header class="sticky top-0 z-40 border-b border-zinc-200/80 bg-zinc-50/80 backdrop-blur-xl dark:border-zinc-800/80 dark:bg-zinc-950/80">
      <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-4 md:px-6">
        <a href={`${BASE}/`} class="group flex items-center gap-2">
          <span class="text-xl font-bold tracking-tight text-zinc-900 transition-colors group-hover:text-zinc-700 dark:text-zinc-100 dark:group-hover:text-zinc-300">SEARO1</span>
          <span class="hidden text-xs font-medium text-zinc-400 sm:inline">Blog</span>
        </a>
        <div class="flex gap-1">
          <a href={`${BASE}/`} class="rounded-lg px-3 py-1.5 text-sm font-medium text-zinc-600 transition-colors hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100">Home</a>
          <a href={`${BASE}/blog/`} class="rounded-lg px-3 py-1.5 text-sm font-medium text-zinc-600 transition-colors hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100">Blog</a>
          <a href={`${BASE}/tags/`} class="rounded-lg px-3 py-1.5 text-sm font-medium text-zinc-600 transition-colors hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100">Tags</a>
          <a href={`${BASE}/about/`} class="rounded-lg px-3 py-1.5 text-sm font-medium text-zinc-600 transition-colors hover:bg-zinc-100 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100">About</a>
        </div>
      </nav>
    </header>
    
    <!-- Main Content -->
    <main class="mx-auto max-w-5xl px-4 py-8 md:px-6 md:py-10">
      <slot />
    </main>
    
    <!-- Decorative Dotted Divider -->
    <div class="mx-auto max-w-5xl px-4 md:px-6">
      <div class="flex items-center justify-center gap-1 py-8">
        <span class="h-1 w-1 rounded-full bg-zinc-300 dark:bg-zinc-700"></span>
        <span class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-600"></span>
        <span class="h-2 w-2 rounded-full bg-zinc-500 dark:bg-zinc-500"></span>
        <span class="h-1.5 w-1.5 rounded-full bg-zinc-400 dark:bg-zinc-600"></span>
        <span class="h-1 w-1 rounded-full bg-zinc-300 dark:bg-zinc-700"></span>
      </div>
    </div>
    
    <!-- Footer -->
    <footer class="border-t border-zinc-200 py-8 text-center dark:border-zinc-800">
      <div class="mb-4 flex items-center justify-center gap-4">
        <a href="https://github.com/SEARO1" target="_blank" rel="noopener noreferrer" class="text-zinc-400 transition-colors hover:text-zinc-600 dark:hover:text-zinc-300">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
        </a>
        <a href={`${BASE}/rss.xml`} class="text-zinc-400 transition-colors hover:text-orange-500 dark:hover:text-orange-400">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
        </a>
      </div>
      <p class="text-sm text-zinc-500 dark:text-zinc-400">
        &copy; 2025–{new Date().getFullYear()} SEARO1 · Built with <a href="https://astro.build" target="_blank" rel="noopener" class="underline hover:text-zinc-700 dark:hover:text-zinc-300">Astro</a> + <a href="https://tailwindcss.com" target="_blank" rel="noopener" class="underline hover:text-zinc-700 dark:hover:text-zinc-300">Tailwind CSS</a>
      </p>
    </footer>
  </body>
</html>