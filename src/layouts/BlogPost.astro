---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { getTagSlug } from "../utils/tags";

type Props = CollectionEntry<"blog">["data"] & {
	headings?: { depth: number; slug: string; text: string }[];
	rawBody?: string;
	slug?: string;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags = [],
	rawBody = "",
} = Astro.props;

const BASE = import.meta.env.BASE_URL;

const chars = rawBody.replace(/\s+/g, "").length;
const minutes = Math.max(1, Math.ceil(chars / 950));
const charsLabel = chars.toLocaleString("en-US");
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${title} | SEARO1 Blog`} description={description} />
	</head>
	<body>
		<div class="reading-progress" aria-hidden="true"></div>
		<Header />

		<main class="blog-post-page page-fade-in min-h-screen min-w-0 w-full py-10 md:py-14" transition:name="page-main" transition:animate="fade">
			<div class="mx-auto min-w-0 px-4 sm:px-6 lg:px-8 max-w-3xl">
				<article class="min-w-0">
					<header class="mb-10 min-w-0 border-b border-zinc-200 pb-6 dark:border-zinc-700">
						<p class="m-0 text-sm text-zinc-500 dark:text-zinc-400">
							<FormattedDate date={pubDate} />
							<span class="mx-1.5">&middot;</span>
							<span>{charsLabel} chars</span>
							<span class="mx-1.5">&middot;</span>
							<span>{minutes} min read</span>
							{updatedDate && (
								<span class="ml-3 inline-block italic">
									Updated <FormattedDate date={updatedDate} />
								</span>
							)}
						</p>

						<h1 class="mt-3 font-sans text-3xl font-semibold leading-tight tracking-tight text-zinc-900 [overflow-wrap:anywhere] dark:text-zinc-100 md:text-4xl">
							{title}
						</h1>

						<p class="mt-3 text-zinc-600 dark:text-zinc-300">{description}</p>

						{tags.length > 0 && (
							<div class="mt-4 flex flex-wrap gap-2">
								{tags.map((tag) => (
									<a
										href={`${BASE}tags/${encodeURIComponent(getTagSlug(tag))}/`}
										class="inline-flex items-center rounded-md border border-zinc-300/90 bg-zinc-50/96 px-2.5 py-1 text-xs font-medium text-zinc-700 no-underline transition-colors duration-150 ease-out hover:border-zinc-400 hover:bg-white hover:text-zinc-900 dark:border-zinc-700/90 dark:bg-zinc-900/96 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-zinc-100"
									>
										#{tag}
									</a>
								))}
							</div>
						)}
					</header>

					<div class="section-enter min-w-0 w-full max-w-none">
						{
							heroImage && (
								<div class="mb-8 aspect-[16/9] overflow-hidden rounded-2xl border border-zinc-200 bg-white dark:border-zinc-700 dark:bg-zinc-900">
									<img src={typeof heroImage === "string" ? heroImage : ""} alt={title} class="h-full w-full object-cover" loading="lazy" />
								</div>
							)
						}

						<div class="markdown-prose min-w-0">
							<slot />
						</div>
					</div>
				</article>
			</div>
		</main>

		<Footer />

		<button type="button" class="back-to-top" data-back-to-top aria-label="Back to top">
			<svg class="back-to-top-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
				<path d="M12 19V5" stroke-linecap="round" />
				<path d="m5 12 7-7 7 7" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
		</button>

		<style is:global>
			.markdown-prose :is(h2, h3, h4) {
				scroll-margin-top: 7rem;
			}
		</style>

		<script is:inline>
			const initBackToTop = () => {
				const button = document.querySelector("[data-back-to-top]");
				if (!(button instanceof HTMLElement)) return;

				let rafId = 0;
				const update = () => {
					rafId = 0;
					if (window.scrollY > 480) {
						button.classList.add("is-visible");
					} else {
						button.classList.remove("is-visible");
					}
				};

				const schedule = () => {
					if (!rafId) rafId = requestAnimationFrame(update);
				};

				if (button.dataset.bound !== "true") {
					button.dataset.bound = "true";
					button.addEventListener("click", () => {
						const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
						window.scrollTo({ top: 0, behavior: reduced ? "auto" : "smooth" });
					});
				}

				window.addEventListener("scroll", schedule, { passive: true });
				update();
			};

			initBackToTop();
			document.addEventListener("astro:page-load", initBackToTop);
			document.addEventListener("astro:after-swap", initBackToTop);
		</script>
	</body>
</html>
